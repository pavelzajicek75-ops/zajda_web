<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zajda | Portfolio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/glightbox/3.2.0/css/glightbox.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #fcfcfc; }
        .bento-card { transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); overflow: hidden; position: relative; border-radius: 2.5rem; }
        .bento-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(0,0,0,0.1); }
        .lang-en { color: #94a3b8; font-style: italic; font-weight: 400; display: block; margin-top: 0.2rem; }
    </style>
</head>
<body class="p-4 md:p-8">
    <header class="max-w-6xl mx-auto mb-12 mt-8 px-4">
        <h1 class="text-7xl md:text-9xl font-black uppercase tracking-tighter leading-none mb-4">Zajda</h1>
        <p class="text-xl md:text-2xl font-medium text-gray-800 italic">Smell the flowers while you can.</p>
    </header>

    <main class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-6 auto-rows-[320px]">
        <div class="md:col-span-2 md:row-span-2 bento-card bg-black group cursor-pointer">
            <img src="https://images.unsplash.com/photo-1542038783-0ad116e109fc?w=1000" class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:scale-105 transition duration-700">
            <div class="absolute inset-0 p-10 flex flex-col justify-end text-white bg-gradient-to-t from-black/80 to-transparent">
                <h2 class="text-4xl font-black uppercase">Fotografování</h2>
                <span class="text-2xl lang-en">Photography</span>
            </div>
        </div>
        <div class="md:col-span-2 bento-card bg-zinc-100 group cursor-pointer">
            <img src="https://images.unsplash.com/photo-1500835595353-b0ad2277dbc4?w=800" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:opacity-50 transition">
            <div class="absolute inset-0 p-10 flex flex-col justify-end">
                <h2 class="text-3xl font-black uppercase italic">Cestování</h2>
                <span class="text-xl lang-en">Travel</span>
            </div>
        </div>
        <div class="md:col-span-1 bento-card bg-orange-500 p-10 flex flex-col justify-between text-white">
            <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-orange-500 font-bold text-2xl">!</div>
            <div><h2 class="text-2xl font-black uppercase">Projekty</h2><span class="text-lg lang-en text-orange-100">Projects</span></div>
        </div>
        <div class="md:col-span-1 bento-card bg-zinc-900 p-10 flex flex-col justify-center text-white text-center">
            <p class="text-xs uppercase tracking-widest opacity-40 mb-2">Kontakt / Contact</p>
            <p class="text-lg font-bold">pavel@zajicek.cz</p>
        </div>
    </main>
</body>
</html>
