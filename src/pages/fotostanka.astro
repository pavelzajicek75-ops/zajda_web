---
let section = null;
let subsections = [];
let articles = [];

if (!import.meta.env.SSR) {
  try {
    const sectionsRes = await fetch("/api/sections");
    const subsectionsRes = await fetch("/api/subsections");
    const articlesRes = await fetch("/api/articles");

    const { sections } = await sectionsRes.json();
    const { subsections: subs } = await subsectionsRes.json();
    const { articles: arts } = await articlesRes.json();

    section = sections.find(s => s.slug === "fotostanka");
    subsections = subs.filter(sub => sub.section_id === section?.id);
    articles = arts.filter(a => a.section_id === section?.id);
  } catch (err) {
    console.error("API error:", err);
  }
}
---

<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <title>Fotostánka</title>
  </head>

  <body>
    <h1>Fotostánka</h1>

    {import.meta.env.SSR ? (
      <p>Obsah se načte až na serveru.</p>
    ) : (
      <>
        <h2>Podsekce</h2>

        {subsections.length === 0 ? (
          <p>Zatím zde nejsou žádné podsekce.</p>
        ) : (
          <ul>
            {subsections.map(sub => (
              <li><a href={`/podsekce/${sub.slug}`}>{sub.name}</a></li>
            ))}
          </ul>
        )}

        <h2>Články</h2>

        {articles.length === 0 ? (
          <p>Zatím zde nejsou žádné články.</p>
        ) : (
          <ul>
            {articles.map(article => (
              <li>
                <a href={`/clanek/${article.slug}`}>{article.title}</a>
              </li>
            ))}
          </ul>
        )}
      </>
    )}
  </body>
</html>
