---
const sections = [
  { id: 1, name: "Cestování" },
  { id: 2, name: "Fotografie" },
  { id: 3, name: "Projekty" },
  { id: 4, name: "Zajda" }
];

// TODO: načítat subsections dynamicky z API
const subsections = [
  { id: 1, section_id: 1, name: "USA 2026" },
  { id: 2, section_id: 1, name: "Island" },
  { id: 3, section_id: 1, name: "Tokyo" },
  { id: 4, section_id: 2, name: "Krajiny" },
  { id: 5, section_id: 2, name: "Města" }
];
---

<section class="page">
  <header class="hero">
    <h1 class="hero-title">NOVÝ ČLÁNEK</h1>
    <p class="hero-subtitle">Vyplň formulář, nahraj fotky, publikuj. Bez souborů, bez Gitu.</p>
  </header>

  <form method="post" action="/api/create-post" enctype="multipart/form-data" class="form">
    <div class="grid">
      <label>
        Název článku
        <input type="text" name="title" required>
      </label>

      <label>
        Krátký popis
        <input type="text" name="description" required>
      </label>
    </div>

    <div class="grid">
      <label>
        Datum
        <input type="date" name="date" required>
      </label>

      <label>
        Tagy (oddělené čárkou)
        <input type="text" name="tags">
      </label>
    </div>

    <div class="grid">
      <label>
        Sekce
        <select name="section_id" required>
          <option value="">Vyber sekci…</option>
          {sections.map((s) => (
            <option value={s.id}>{s.name}</option>
          ))}
        </select>
      </label>

      <label>
        Podsekce
        <select name="subsection_id">
          <option value="">(volitelné)</option>
          {subsections.map((ss) => (
            <option value={ss.id}>{ss.name}</option>
          ))}
        </select>
      </label>
    </div>

    <label>
      Obsah článku
      <textarea name="content" rows="10" required></textarea>
    </label>

    <label>
      Fotky (můžeš nahrát více)
      <input type="file" name="photos" multiple accept="image/*">
    </label>

    <button type="submit" class="btn">Publikovat článek</button>
  </form>
</section>

<style>
  :root { color-scheme: dark; }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top, rgba(255, 140, 58, 0.18), transparent 55%),
      radial-gradient(circle at 10% 90%, rgba(120, 80, 255, 0.18), transparent 55%),
      #050509;
    font-family: system-ui, sans-serif;
    color: #f3f3f3;
  }

  .page {
    max-width: 900px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 2rem;
  }

  .hero-title {
    font-size: 2.8rem;
    font-weight: 900;
    background: linear-gradient(120deg, #ffe8c8, #ff8c3a);
    -webkit-background-clip: text;
    color: transparent;
    text-shadow: 0 0 22px rgba(255, 140, 58, 0.55);
  }

  .hero-subtitle {
    color: #d0d0dd;
    margin-bottom: 2rem;
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    background: rgba(10, 10, 18, 0.85);
    padding: 2rem;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(6px);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  label {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.95rem;
  }

  input, textarea, select {
    padding: 0.8rem;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.05);
    color: #fff;
    font-size: 1rem;
  }

  .btn {
    padding: 1rem;
    border-radius: 12px;
    background: linear-gradient(120deg, #ff8c3a, #ffb87a);
    color: #000;
    font-weight: 700;
    border: none;
    cursor: pointer;
    transition: 0.2s;
  }

  .btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(255, 140, 58, 0.4);
  }
</style>
