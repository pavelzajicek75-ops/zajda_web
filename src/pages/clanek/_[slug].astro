---
import Layout from '../../layouts/Layout.astro';
import articles from '../../../data/articles.json';

// Slug z URL
const { slug } = Astro.params;

// Najdeme článek podle slugu
const article = articles.find(a => a.slug === slug);

if (!article) {
  throw new Error(`Článek se slugem "${slug}" nebyl nalezen.`);
}

// STATIC BUILD: vygenerujeme všechny cesty
export async function getStaticPaths() {
  return articles
    .filter(a => a.slug && a.slug.length > 0)
    .map(a => ({
      params: { slug: a.slug }
    }));
}
---

<Layout title={article.title}>
  <article class="content">
    <h1>{article.title}</h1>

    {article.date && (
      <p class="date">{article.date}</p>
    )}

    <div class="text">
      {article.content}
    </div>
  </article>
</Layout>

<style>
  :global(body) {
    background: #05060a;
    color: #f5f5f5;
  }

  .content {
    max-width: 800px;
    margin: 3rem auto;
    padding: 1rem;
  }

  h1 {
    font-size: 2.4rem;
    margin-bottom: 1rem;
  }

  .date {
    opacity: 0.6;
    margin-bottom: 2rem;
  }

  .text {
    line-height: 1.7;
    font-size: 1.1rem;
    white-space: pre-wrap;
  }
</style>
