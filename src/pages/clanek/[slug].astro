---
import { readFileSync } from "fs";
import path from "path";

// 🔹 1) Načteme články z lokálního JSON souboru
const filePath = path.resolve("src/data/cestovani/usa2026/articles.json");
const articles = JSON.parse(readFileSync(filePath, "utf-8"));

// 🔹 2) Definujeme getStaticPaths pro Astro
export async function getStaticPaths() {
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

// 🔹 3) Získáme data pro konkrétní článek
const { article } = Astro.props;
---

<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <title>{article.title}</title>
  </head>

  <body>
    <h1>{article.title}</h1>
    <p><strong>Datum:</strong> {article.date}</p>
    <p><strong>Sekce:</strong> {article.section}</p>

    <article>
      <p>{article.content}</p>
    </article>

    <p><a href="/cestovani/clanky">← Zpět na seznam článků</a></p>
  </body>
</html>
