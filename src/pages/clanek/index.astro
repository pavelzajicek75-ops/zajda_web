---
import Layout from '../../layouts/MainLayout.astro';
import articles from '../../../data/articles.json';

// Seřadíme články podle data (nejnovější nahoře)
const sorted = [...articles].sort((a, b) => {
  const da = new Date(a.date || 0).getTime();
  const db = new Date(b.date || 0).getTime();
  return db - da;
});
---

<Layout title="Články">
  <section class="content">
    <h1>Články</h1>

    <div class="list">
      {sorted.map(article => (
        <a href={`/clanek/${article.slug}`} class="item">
          <h2>{article.title}</h2>
          {article.date && <p class="date">{article.date}</p>}
          <p class="preview">
            {article.content?.slice(0, 120)}…
          </p>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  :global(body) {
    background: #05060a;
    color: #f5f5f5;
  }

  .content {
    max-width: 900px;
    margin: 3rem auto;
    padding: 1rem;
  }

  h1 {
    font-size: 2.6rem;
    margin-bottom: 2rem;
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .item {
    display: block;
    padding: 1.2rem 1.4rem;
    background: #0f1117;
    border-radius: 10px;
    text-decoration: none;
    color: #f5f5f5;
    border: 1px solid #1e293b;
    transition: 0.2s;
  }

  .item:hover {
    background: #1a1d25;
    border-color: #334155;
  }

  .item h2 {
    margin: 0 0 0.4rem 0;
    font-size: 1.6rem;
  }

  .date {
    opacity: 0.6;
    margin-bottom: 0.6rem;
  }

  .preview {
    opacity: 0.8;
    font-size: 1rem;
  }
</style>
