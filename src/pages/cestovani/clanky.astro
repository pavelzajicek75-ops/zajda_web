---
let section = null;
let filteredArticles = [];
let subsections = [];

// Během buildu (SSR) nesmíme volat API
if (!import.meta.env.SSR) {
  const sectionsRes = await fetch("/api/sections");
  const subsectionsRes = await fetch("/api/subsections");
  const articlesRes = await fetch("/api/articles");

  const { sections } = await sectionsRes.json();
  const { subsections: subs } = await subsectionsRes.json();
  const { articles } = await articlesRes.json();

  subsections = subs;

  section = sections.find(s => s.slug === "cestovani");
  filteredArticles = articles.filter(a => a.section_id === section.id);
}
---

<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <title>Články – Cestování</title>
  </head>

  <body>
    <h1>Články – Cestování</h1>

    {import.meta.env.SSR ? (
      <p>Obsah se načte až na serveru.</p>
    ) : (
      <>
        {filteredArticles.length === 0 ? (
          <p>Zatím zde nejsou žádné články.</p>
        ) : (
          <ul>
            {filteredArticles.map(article => (
              <li>
                <a href={`/clanek/${article.slug}`}>
                  <strong>{article.title}</strong>
                </a>
                <br />
                <small>
                  Podsekce: {
                    subsections.find(s => s.id === article.subsection_id)?.name
                  }
                </small>
              </li>
            ))}
          </ul>
        )}
      </>
    )}
  </body>
</html>
