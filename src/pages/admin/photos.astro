---
import Layout from "../../layouts/AdminLayout.astro";

let photos = [];

try {
  const res = await fetch("/api/photos/list");
  const data = await res.json();
  if (data.success) {
    photos = data.files;
  }
} catch (e) {
  console.error("Failed to load photos:", e);
}

// Funkce pro mazání (běží v prohlížeči)
const deletePhoto = async (key) => {
  if (!confirm(`Opravdu smazat ${key}?`)) return;

  const res = await fetch("/api/photos/delete", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ key })
  });

  const data = await res.json();

  if (data.success) {
    alert("Smazáno.");
    location.reload();
  } else {
    alert("Chyba při mazání: " + data.error);
  }
};
---

<Layout title="Fotky v R2">
  <h1>📸 Fotky v R2</h1>

  {photos.length === 0 && (
    <p>Žádné fotky zatím nejsou nahrané.</p>
  )}

  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; margin-top: 20px;">
    {photos.map(photo => (
      <div style="background: #1a1a1a; padding: 10px; border-radius: 8px;">
        <img 
          src={photo.url} 
          alt={photo.key} 
          style="width: 100%; height: 150px; object-fit: cover; border-radius: 6px;"
        />
        <div style="margin-top: 10px; font-size: 14px;">
          <strong>{photo.key}</strong><br />
          Velikost: {(photo.size / 1024).toFixed(1)} KB<br />
          Nahráno: {new Date(photo.uploaded).toLocaleString()}
        </div>

        <button 
          style="
            margin-top: 10px;
            width: 100%;
            padding: 8px;
            background: #c62828;
            border: none;
            border-radius: 6px;
            color: white;
            cursor: pointer;
          "
          onClick={() => deletePhoto(photo.key)}
        >
          🗑️ Smazat
        </button>
      </div>
    ))}
  </div>
</Layout>
