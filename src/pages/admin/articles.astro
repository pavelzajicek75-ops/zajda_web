---
import AdminLayout from "../../layouts/AdminLayout.astro";
import articles from "../../../data/articles.json";
---

<AdminLayout title="Články">

  <h1>Články</h1>

  <table>
    <thead>
      <tr>
        <th>Foto</th>
        <th>Název</th>
        <th>Datum</th>
        <th>ID</th>
        <th>Akce</th>
      </tr>
    </thead>

    <tbody>
      {articles.map((a) => (
        <tr>
          <td>
            {a.image && (
              <img
                src={a.image}
                alt={a.title}
                style="width:80px;height:50px;object-fit:cover;border-radius:6px;"
              />
            )}
          </td>
          <td>{a.title}</td>
          <td>{a.date}</td>
          <td>{a.id}</td>
          <td>
            <a
              href={`/admin/edit/${a.id}`}
              style="
                padding:6px 12px;
                background:#4a90e2;
                color:white;
                border-radius:6px;
                text-decoration:none;
              "
            >
              Upravit
            </a>
          </td>
        </tr>
      ))}
    </tbody>
  </table>

</AdminLayout>
