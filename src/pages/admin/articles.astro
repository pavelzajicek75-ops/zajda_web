---
import Layout from "../../layouts/Layout.astro";

if (!import.meta.env.SSR) {
  const token = localStorage.getItem("admin_token");
  if (!token) {
    window.location.href = "/admin/login";
  }
}
---

<Layout title="Články">
  <h1>Správa článků</h1>
  <p>Zde můžeš upravovat, mazat nebo přidávat nové články.</p>
</Layout>
