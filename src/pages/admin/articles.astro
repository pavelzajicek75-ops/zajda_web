---
import AdminLayout from "../../layouts/AdminLayout.astro";
import articlesData from "../../data/articles.json";

// 🔥 Seřadíme články podle data (nejnovější nahoře)
const articles = [...articlesData].sort((a, b) => {
  return new Date(b.date) - new Date(a.date);
});
---

<AdminLayout title="Články">
  <h1>Seznam článků</h1>

  <table>
    <thead>
      <tr>
        <th>Obrázek</th>
        <th>Název</th>
        <th>Datum</th>
        <th>ID</th>
        <th>Akce</th>
      </tr>
    </thead>

    <tbody>
      {articles.map((a) => (
        <tr>
          <td>
            {a.image ? (
              <img src={a.image} alt={a.title} class="thumb" />
            ) : (
              <span class="noimg">—</span>
            )}
          </td>

          <td>{a.title}</td>
          <td>{a.date}</td>
          <td>{a.id}</td>

          <td>
            <a class="edit" href={`/admin/edit/${a.id}`}>Upravit</a>
            <button class="delete" onclick={`deleteArticle('${a.id}')`}>Smazat</button>
          </td>
        </tr>
      ))}
    </tbody>
  </table>

  <style>
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 20px;
      background: #1e1e1e;
      border-radius: 8px;
      overflow: hidden;
    }

    th, td {
      padding: 12px;
      border-bottom: 1px solid #333;
      vertical-align: middle;
    }

    th {
      background: #2a2a2a;
      text-align: left;
    }

    .thumb {
      width: 60px;
      height: 60px;
      object-fit: cover;
      border-radius: 6px;
      border: 1px solid #444;
    }

    .noimg {
      color: #666;
      font-size: 14px;
    }

    .edit {
      color: #4a90e2;
      margin-right: 10px;
      text-decoration: none;
    }

    .delete {
      background: #ff6b6b;
      border: none;
      padding: 6px 12px;
      border-radius: 6px;
      cursor: pointer;
      color: white;
    }

    .delete:hover {
      background: #ff4b4b;
    }
  </style>

  <script>
    async function deleteArticle(id) {
      if (!confirm("Opravdu smazat článek?")) return;

      const token = localStorage.getItem("admin_token");

      const res = await fetch("/api/admin/delete", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Authorization": "Bearer " + token
        },
        body: JSON.stringify({ id })
      });

      const data = await res.json();

      if (data.deleted) {
        alert("Článek smazán");
        location.reload();
      } else {
        alert("Chyba při mazání");
      }
    }
  </script>
</AdminLayout>
