---
import AdminLayout from '../../../layouts/AdminLayout.astro';

const { id } = Astro.params;
const article = articles.find(a => String(a.id) === String(id));

if (!article) {
  throw new Error(`Článek s ID ${id} nebyl nalezen.`);
}

export async function getStaticPaths() {
  return articles.map(a => ({
    params: { id: String(a.id) }
  }));
}
---

<AdminLayout title={`Upravit: ${article.title}`}>

  <h1>Upravit článek</h1>

  <div class="layout">
    <form id="editForm" class="meta">

      <label>Sekce</label>
      <select id="section"></select>

      <label>Podsekce</label>
      <select id="subsection"></select>

      <label>Datum</label>
      <input type="date" id="date" value={article.date} />

      <label>Místo</label>
      <input type="text" id="location" value={article.location || ""} />

      <label>Název článku</label>
      <input type="text" id="title" value={article.title} />

      <button type="button" id="saveBtn" class="primary">💾 Uložit změny</button>
    </form>

    <div class="editor-card">
      <div id="tiptap-editor" class="tiptap"></div>
    </div>
  </div>

  <script type="module">
    import { Editor } from "https://cdn.skypack.dev/@tiptap/core";
    import StarterKit from "https://cdn.skypack.dev/@tiptap/starter-kit";

    const editor = new Editor({
      element: document.querySelector("#tiptap-editor"),
      extensions: [StarterKit],
      content: `{article.content}`
    });

    // 🔥 Načtení sekcí
    const res = await fetch("/data/sections.json");
    const sectionsData = await res.json();

    const sectionSelect = document.getElementById("section");
    const subsectionSelect = document.getElementById("subsection");

    // Naplnění sekcí
    Object.keys(sectionsData).forEach(sec => {
      const opt = document.createElement("option");
      opt.value = sec;
      opt.textContent = sec;
      sectionSelect.appendChild(opt);
    });

    // Nastavení aktuální sekce
    sectionSelect.value = "{article.section}";

    // Naplnění podsekcí
    function fillSubsections() {
      subsectionSelect.innerHTML = "";
      const subs = sectionsData[sectionSelect.value] || [];
      subs.forEach(sub => {
        const opt = document.createElement("option");
        opt.value = sub;
        opt.textContent = sub;
        subsectionSelect.appendChild(opt);
      });
    }

    fillSubsections();

    // Nastavení aktuální podsekce
    subsectionSelect.value = "{article.subsection}";

    sectionSelect.addEventListener("change", fillSubsections);

    // Uložení
    document.getElementById("saveBtn").onclick = async () => {
      const token = localStorage.getItem("admin_token");

      const body = {
        id: "{id}",
        title: document.getElementById("title").value,
        date: document.getElementById("date").value,
        location: document.getElementById("location").value,
        section: sectionSelect.value,
        subsection: subsectionSelect.value,
        content: editor.getHTML()
      };

      const res = await fetch("/api/admin/save", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Authorization": "Bearer " + token
        },
        body: JSON.stringify(body)
      });

      const data = await res.json();

      if (data.success) {
        alert("Článek uložen");
        window.location.href = "/admin/articles";
      } else {
        alert("Chyba při ukládání");
      }
    };
  </script>

</AdminLayout>
