---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import articles from '../../../../data/articles.json';

// Získáme ID z URL
const { id } = Astro.params;

// Najdeme článek podle ID
const article = articles.find(a => String(a.id) === String(id));

if (!article) {
  throw new Error(`Článek s ID ${id} nebyl nalezen.`);
}
---

<AdminLayout title={`Upravit: ${article.title}`}>
  <section class="header">
    <h1>Upravit článek</h1>
    <p>ID: {id}</p>
  </section>

  <form id="editForm">
    <label>
      Název článku
      <input type="text" name="title" value={article.title} required />
    </label>

    <label>
      Slug (URL)
      <input type="text" name="slug" value={article.slug} />
    </label>

    <label>
      Sekce
      <input type="text" name="section" value={article.section} />
    </label>

    <label>
      Podsekce
      <input type="text" name="subsection" value={article.subsection} />
    </label>

    <label>
      Datum
      <input type="date" name="date" value={article.date} />
    </label>

    <label>
      Obsah článku
      <textarea name="content" rows="10">{article.content}</textarea>
    </label>

    <button type="submit" class="btn-primary">Uložit změny</button>
  </form>

  <script>
    const form = document.getElementById('editForm');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const data = Object.fromEntries(new FormData(form).entries());
      data.id = {id};

      const response = await fetch('/api/articles/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      if (response.ok) {
        window.location.href = '/admin/articles';
      } else {
        alert('Nepodařilo se uložit změny.');
      }
    });
  </script>
</AdminLayout>

<style>
  :global(body) {
    background: #05060a;
    color: #f5f5f5;
  }

  .header {
    margin-bottom: 2rem;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  label {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-weight: 500;
  }

  input, textarea {
    background: #0f172a;
    border: 1px solid #1e293b;
    padding: 0.7rem 1rem;
    border-radius: 0.5rem;
    color: #f5f5f5;
  }

  .btn-primary {
    padding: 0.8rem 1.4rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #22c55e, #16a34a);
    color: #020617;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 0 20px rgba(34, 197, 94, 0.35);
    border: none;
    cursor: pointer;
    margin-top: 1rem;
  }
</style>
