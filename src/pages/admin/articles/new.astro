---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import sections from "../../../data/sections.json";

const sectionsData = sections;
---

<AdminLayout title="Nový článek">

  <h1>Nový článek</h1>

  <div class="layout">
    <form id="articleForm" class="meta">

      <label>Název článku</label>
      <input type="text" id="title" placeholder="Název článku" />

      <label>Datum</label>
      <input
        type="date"
        id="date"
        value={new Date().toISOString().split("T")[0]}
      />

      <label>Místo</label>
      <input type="text" id="location" placeholder="např. Brno, New York…" />

      <label>Sekce</label>
      <select id="section"></select>

      <label>Podsekce</label>
      <select id="subsection"></select>

      <button type="button" id="saveBtn" class="primary">💾 Uložit článek</button>
    </form>

    <div class="editor-card">
      <div class="editor-toolbar" id="tiptap-toolbar">
        <button type="button" data-action="bold"><b>B</b></button>
        <button type="button" data-action="italic"><i>I</i></button>
        <button type="button" data-action="heading1">H1</button>
        <button type="button" data-action="heading2">H2</button>
        <button type="button" data-action="bulletList">• List</button>
        <button type="button" data-action="orderedList">1. List</button>
        <button type="button" data-action="blockquote">„“</button>
        <button type="button" data-action="codeBlock">{`</>`}</button>
        <button type="button" id="uploadImageBtn">📷 Vložit fotku</button>
      </div>
      <div id="tiptap-editor" class="tiptap"></div>
    </div>
  </div>

  <style>
    h1 {
      margin-bottom: 20px;
    }

    .layout {
      display: grid;
      grid-template-columns: minmax(260px, 320px) minmax(0, 1fr);
      gap: 24px;
      align-items: flex-start;
    }

    .meta {
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 16px;
      border-radius: 12px;
      background: #141414;
      border: 1px solid #2a2a2a;
    }

    label {
      font-size: 0.85rem;
      color: #aaa;
    }

    input, select {
      padding: 10px 12px;
      border-radius: 8px;
      border: 1px solid #333;
      background: #1b1b1b;
      color: #f5f5f5;
      font-size: 0.95rem;
    }

    input:focus, select:focus {
      outline: none;
      border-color: #4a90e2;
      box-shadow: 0 0 0 1px #4a90e233;
    }

    .primary {
      margin-top: 10px;
      padding: 10px 14px;
      border-radius: 8px;
      border: none;
      background: #4a90e2;
      color: white;
      font-weight: 500;
      cursor: pointer;
    }

    .primary:hover {
      background: #357ac8;
    }

    .editor-card {
      border-radius: 12px;
      background: #101010;
      border: 1px solid #2a2a2a;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    .editor-toolbar {
      display: flex;
      gap: 6px;
      padding: 8px;
      border-bottom: 1px solid #2a2a2a;
      background: #151515;
      position: sticky;
      top: 0;
      z-index: 5;
    }

    .editor-toolbar button {
      background: #1f1f1f;
      border: 1px solid #333;
      color: #ddd;
      padding: 6px 10px;
      border-radius: 6px;
      font-size: 0.8rem;
      cursor: pointer;
    }

    .editor-toolbar button:hover {
      background: #2a2a2a;
    }

    .tiptap {
      min-height: 380px;
      padding: 14px 16px;
      color: #f5f5f5;
      font-size: 0.95rem;
    }

    .tiptap p {
      margin: 0 0 0.6em;
    }

    .tiptap h1, .tiptap h2, .tiptap h3 {
      margin: 0.8em 0 0.4em;
    }

    .tiptap ul, .tiptap ol {
      padding-left: 1.4em;
      margin: 0.4em 0;
    }

    .tiptap blockquote {
      border-left: 3px solid #4a90e2;
      margin: 0.6em 0;
      padding-left: 0.8em;
      color: #aaa;
    }

    .tiptap pre {
      background: #181818;
      padding: 8px 10px;
      border-radius: 6px;
      font-family: monospace;
      font-size: 0.85rem;
      overflow-x: auto;
    }

    .tiptap img {
      max-width: 100%;
      border-radius: 8px;
      margin: 10px 0;
    }

    @media (max-width: 900px) {
      .layout {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <!-- TipTap přes CDN (starter kit) -->
  <script type="module">
    import { Editor } from "https://cdn.skypack.dev/@tiptap/core";
    import StarterKit from "https://cdn.skypack.dev/@tiptap/starter-kit";
    import Image from "https://cdn.skypack.dev/@tiptap/extension-image";

    const editor = new Editor({
      element: document.querySelector("#tiptap-editor"),
      extensions: [
        StarterKit,
        Image
      ],
      content: "<p>Napiš svůj článek…</p>"
    });

    // Sekce + podsekce
    const sectionsData = JSON.parse(`<?= JSON.stringify(sectionsData) ?>`);
    const sectionSelect = document.getElementById("section");
    const subsectionSelect = document.getElementById("subsection");

    Object.keys(sectionsData).forEach(sec => {
      const opt = document.createElement("option");
      opt.value = sec;
      opt.textContent = sec;
      sectionSelect.appendChild(opt);
    });

    sectionSelect.addEventListener("change", () => {
      subsectionSelect.innerHTML = "";
      const subs = sectionsData[sectionSelect.value] || [];
      subs.forEach(sub => {
        const opt = document.createElement("option");
        opt.value = sub;
        opt.textContent = sub;
        subsectionSelect.appendChild(opt);
      });
    });

    sectionSelect.dispatchEvent(new Event("change"));

    // Toolbar akce
    const toolbar = document.getElementById("tiptap-toolbar");
    toolbar.addEventListener("click", (e) => {
      const btn = e.target.closest("button");
      if (!btn) return;
      const action = btn.dataset.action;
      if (!action) return;

      switch (action) {
        case "bold":
          editor.chain().focus().toggleBold().run();
          break;
        case "italic":
          editor.chain().focus().toggleItalic().run();
          break;
        case "heading1":
          editor.chain().focus().toggleHeading({ level: 1 }).run();
          break;
        case "heading2":
          editor.chain().focus().toggleHeading({ level: 2 }).run();
          break;
        case "bulletList":
          editor.chain().focus().toggleBulletList().run();
          break;
        case "orderedList":
          editor.chain().focus().toggleOrderedList().run();
          break;
        case "blockquote":
          editor.chain().focus().toggleBlockquote().run();
          break;
        case "codeBlock":
          editor.chain().focus().toggleCodeBlock().run();
          break;
      }
    });

    // Vložit fotku – hook na náš upload workflow
    document.getElementById("uploadImageBtn").addEventListener("click", async () => {
      const input = document.createElement("input");
      input.type = "file";
      input.accept = "image/*";
      input.click();

      input.onchange = async () => {
        const file = input.files[0];
        if (!file) return;

        const formData = new FormData();
        formData.append("file", file);

        const res = await fetch("/api/upload/image", {
          method: "POST",
          body: formData
        });

        const data = await res.json();
        if (data.success && data.url) {
          editor.chain().focus().setImage({ src: data.url }).run();
        }
      };
    });

    // Uložit článek
    document.getElementById("saveBtn").addEventListener("click", async () => {
      const body = {
        title: document.getElementById("title").value,
        date: document.getElementById("date").value,
        location: document.getElementById("location").value,
        section: document.getElementById("section").value,
        subsection: document.getElementById("subsection").value,
        content: editor.getHTML()
      };

      const res = await fetch("/api/articles/save", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body)
      });

      const data = await res.json();
      if (data.success) {
        alert("Článek uložen");
        window.location.href = "/admin/articles";
      }
    });
  </script>

</AdminLayout>
