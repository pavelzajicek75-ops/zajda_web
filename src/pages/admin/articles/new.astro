---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import sections from "../../../data/sections.json";
---

<AdminLayout title="Nový článek">

  <h1>Nový článek</h1>

  <form id="articleForm">

    <label>Název článku</label>
    <input type="text" id="title" placeholder="Název článku" />

    <label>Datum</label>
    <input type="date" id="date" />

    <label>Místo</label>
    <input type="text" id="location" placeholder="např. Brno, New York…" />

    <label>Sekce</label>
    <select id="section"></select>

    <label>Podsekce</label>
    <select id="subsection"></select>

    <label>Obsah článku</label>
    <div id="editor"></div>

    <button type="button" id="uploadImageBtn">📷 Vložit fotku</button>
    <button type="button" id="saveBtn">💾 Uložit článek</button>

  </form>

  <style>
    form {
      display: flex;
      flex-direction: column;
      gap: 15px;
      max-width: 800px;
    }

    input, select {
      padding: 12px;
      border-radius: 8px;
      border: 1px solid #444;
      background: #1e1e1e;
      color: white;
      font-size: 16px;
    }

    #editor {
      height: 350px;
      background: #1e1e1e;
      color: white;
      border-radius: 8px;
    }

    button {
      padding: 12px;
      background: #4a90e2;
      border: none;
      border-radius: 8px;
      color: white;
      font-size: 16px;
      cursor: pointer;
      margin-top: 10px;
    }

    button:hover {
      background: #357ac8;
    }
  </style>

  <!-- Quill editor -->
  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
  <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>

  <script>
    // Inicializace editoru
    const quill = new Quill("#editor", {
      theme: "snow"
    });

    // Sekce a podsekce
    const sectionsData = JSON.parse(`<?=
      JSON.stringify(sections)
    ?>`);

    const sectionSelect = document.getElementById("section");
    const subsectionSelect = document.getElementById("subsection");

    Object.keys(sectionsData).forEach(sec => {
      const opt = document.createElement("option");
      opt.value = sec;
      opt.textContent = sec;
      sectionSelect.appendChild(opt);
    });

    sectionSelect.addEventListener("change", () => {
      subsectionSelect.innerHTML = "";
      sectionsData[sectionSelect.value].forEach(sub => {
        const opt = document.createElement("option");
        opt.value = sub;
        opt.textContent = sub;
        subsectionSelect.appendChild(opt);
      });
    });

    sectionSelect.dispatchEvent(new Event("change"));

    // Vložit fotku (workflow uložený v projektu)
    document.getElementById("uploadImageBtn").addEventListener("click", async () => {
      const input = document.createElement("input");
      input.type = "file";
      input.accept = "image/*";
      input.click();

      input.onchange = async () => {
        const file = input.files[0];
        if (!file) return;

        const formData = new FormData();
        formData.append("file", file);

        // Upload do R2
        const res = await fetch("/api/upload/image", {
          method: "POST",
          body: formData
        });

        const data = await res.json();

        if (data.success) {
          // Vložit obrázek do článku
          quill.insertEmbed(quill.getLength(), "image", data.url);
        }
      };
    });

    // Uložit článek
    document.getElementById("saveBtn").addEventListener("click", async () => {
      const body = {
        title: document.getElementById("title").value,
        date: document.getElementById("date").value,
        location: document.getElementById("location").value,
        section: document.getElementById("section").value,
        subsection: document.getElementById("subsection").value,
        content: quill.root.innerHTML
      };

      const res = await fetch("/api/articles/save", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body)
      });

      const data = await res.json();

      if (data.success) {
        alert("Článek uložen");
        window.location.href = "/admin/articles";
      }
    });
  </script>

</AdminLayout>
