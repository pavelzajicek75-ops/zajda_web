---
import AdminLayout from '../../layouts/AdminLayout.astro';
import articles from '../../../data/articles.json';

// Seřadíme články podle data (nejnovější nahoře)
const sortedArticles = [...articles].sort((a, b) => {
  const da = new Date(a.date || 0).getTime();
  const db = new Date(b.date || 0).getTime();
  return db - da;
});
---

<AdminLayout title="Články">
  <section class="header">
    <div>
      <h1>Články</h1>
      <p>Správa všech článků na webu.</p>
    </div>

    <a href="/admin/articles/new" class="btn-primary">+ Nový článek</a>
  </section>

  {sortedArticles.length === 0 ? (
    <div class="empty">
      <p>Nemáš žádné články.</p>
      <a href="/admin/articles/new" class="btn-primary">Vytvořit první článek</a>
    </div>
  ) : (
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Název</th>
            <th>Sekce</th>
            <th>Podsekce</th>
            <th>Datum</th>
            <th>Stav</th>
            <th></th>
          </tr>
        </thead>

        <tbody>
          {sortedArticles.map((article) => (
            <tr>
              <td class="title-cell">
                <span class="title">{article.title}</span>
                {article.slug && <span class="slug">/{article.slug}</span>}
              </td>

              <td>{article.section || '—'}</td>
              <td>{article.subsection || '—'}</td>

              <td>
                {article.date
                  ? new Date(article.date).toLocaleDateString('cs-CZ')
                  : '—'}
              </td>

              <td>
                <span class={`status ${article.published ? 'published' : 'draft'}`}>
                  {article.published ? 'Publikováno' : 'Koncept'}
                </span>
              </td>

              <td class="actions">
                <a href={`/admin/articles/${article.id}`} class="link">Upravit</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>

<style>
  :global(body) {
    background: #05060a;
    color: #f5f5f5;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2rem;
  }

  .btn-primary {
    padding: 0.6rem 1.2rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #22c55e, #16a34a);
    color: #020617;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 0 20px rgba(34, 197, 94, 0.35);
  }

  .empty {
    border: 1px dashed #1f2937;
    padding: 2rem;
    text-align: center;
    border-radius: 1rem;
  }

  .table-wrapper {
    border-radius: 1rem;
    border: 1px solid #111827;
    overflow: hidden;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  thead {
    background: rgba(15, 23, 42, 0.95);
  }

  th, td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #111827;
  }

  .title-cell {
    display: flex;
    flex-direction: column;
  }

  .slug {
    font-size: 0.8rem;
    color: #6b7280;
  }

  .status {
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-size: 0.75rem;
  }

  .status.published {
    background: rgba(34, 197, 94, 0.12);
    color: #4ade80;
  }

  .status.draft {
    background: rgba(148, 163, 184, 0.12);
    color: #e5e7eb;
  }

  .actions .link {
    color: #60a5fa;
    text-decoration: none;
  }
</style>
