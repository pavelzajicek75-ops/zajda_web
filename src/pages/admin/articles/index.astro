---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import articles from '../../../../data/articles.json';

// Seřadíme články podle data (nejnovější nahoře)
const sortedArticles = [...articles].sort((a, b) => {
  const da = new Date(a.date || 0).getTime();
  const db = new Date(b.date || 0).getTime();
  return db - da;
});
---

<AdminLayout title="Články">
  <section class="header">
    <h1>Články</h1>
    <a href="/admin/articles/new" class="btn-primary">+ Nový článek</a>
  </section>

  <table class="article-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Název</th>
        <th>Slug</th>
        <th>Sekce</th>
        <th>Datum</th>
        <th>Akce</th>
      </tr>
    </thead>

    <tbody>
      {sortedArticles.map(article => (
        <tr>
          <td>{article.id}</td>
          <td>{article.title}</td>
          <td>{article.slug}</td>
          <td>{article.section}</td>
          <td>{article.date}</td>
          <td class="actions">
            <a href={`/admin/edit/${article.id}`} class="btn-edit">Upravit</a>
            <button class="btn-delete" data-id={article.id}>Smazat</button>
          </td>
        </tr>
      ))}
    </tbody>
  </table>

  <script>
    document.querySelectorAll('.btn-delete').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id;

        if (!confirm(`Opravdu chceš smazat článek ID ${id}?`)) {
          return;
        }

        const response = await fetch('/api/articles/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id })
        });

        const result = await response.json();

        if (result.success) {
          alert('Článek byl smazán.');
          location.reload();
        } else {
          alert('Mazání se nepodařilo.');
        }
      });
    });
  </script>
</AdminLayout>

<style>
  :global(body) {
    background: #05060a;
    color: #f5f5f5;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .article-table {
    width: 100%;
    border-collapse: collapse;
  }

  th, td {
    padding: 0.8rem;
    border-bottom: 1px solid #1e293b;
  }

  .actions {
    display: flex;
    gap: 0.5rem;
  }

  .btn-edit {
    padding: 0.4rem 0.8rem;
    background: #3b82f6;
    border-radius: 6px;
    color: white;
    text-decoration: none;
  }

  .btn-delete {
    padding: 0.4rem 0.8rem;
    background: #ef4444;
    border-radius: 6px;
    color: white;
    border: none;
    cursor: pointer;
  }

  .btn-primary {
    padding: 0.8rem 1.4rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #22c55e, #16a34a);
    color: #020617;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 0 20px rgba(34, 197, 94, 0.35);
    border: none;
  }
</style>
