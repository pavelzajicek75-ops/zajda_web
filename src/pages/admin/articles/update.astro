---
import Layout from "../../../layouts/AdminLayout.astro";

const id = Astro.params.id;

// Načtení článku
let article = {};
try {
  const res = await fetch(`/api/articles/get?id=${id}`);
  article = await res.json();
} catch (e) {
  console.error("Failed to load article:", e);
}

// Načtení fotek
let photos = [];
try {
  const res = await fetch("/api/photos/list");
  const data = await res.json();
  if (data.success) {
    photos = data.files;
  }
} catch (e) {
  console.error("Failed to load photos:", e);
}

// Funkce pro vložení fotky
const insertPhoto = (url) => {
  const textarea = document.getElementById("content");
  const cursor = textarea.selectionStart;

  const before = textarea.value.substring(0, cursor);
  const after = textarea.value.substring(cursor);

  const insert = `\n<img src="${url}" alt="" />\n`;

  textarea.value = before + insert + after;
  textarea.focus();
};
---

<Layout title="Upravit článek">
  <h1>✏️ Upravit článek</h1>

  <form method="post" action="/api/articles/update">
    <input type="hidden" name="id" value={id} />

    <label>Nadpis</label>
    <input type="text" name="title" value={article.title} required />

    <label>Obsah</label>
    <textarea id="content" name="content" rows="15" required>{article.content}</textarea>

    <button type="submit">💾 Uložit změny</button>
  </form>

  <h2 style="margin-top: 40px;">📸 Fotky — kliknutím vložíš do článku</h2>

  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 15px; margin-top: 20px;">
    {photos.map(photo => (
      <div 
        style="background: #1a1a1a; padding: 10px; border-radius: 8px; cursor: pointer;"
        onClick={() => insertPhoto(photo.url)}
      >
        <img 
          src={photo.url} 
          alt={photo.key} 
          style="width: 100%; height: 120px; object-fit: cover; border-radius: 6px;"
        />
        <div style="margin-top: 8px; font-size: 13px; text-align: center;">
          {photo.key}
        </div>
      </div>
    ))}
  </div>
</Layout>
