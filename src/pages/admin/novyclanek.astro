<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <title>Nový článek</title>

    <!-- CropperJS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" rel="stylesheet" />

    <style>
      :root { color-scheme: dark; }
      body {
        margin: 0;
        background: #050509;
        font-family: system-ui, sans-serif;
        color: #f3f3f3;
      }
      .page {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem;
      }
      h1 {
        font-size: 2.6rem;
        margin-bottom: 1.5rem;
        background: linear-gradient(120deg, #ffe8c8, #ff8c3a);
        -webkit-background-clip: text;
        color: transparent;
      }
      .form {
        display: flex;
        flex-direction: column;
        gap: 1.4rem;
        background: rgba(255,255,255,0.05);
        padding: 2rem;
        border-radius: 16px;
      }
      input, textarea, select {
        padding: 0.8rem;
        border-radius: 10px;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        color: white;
      }
      .btn {
        padding: 1rem;
        background: orange;
        border: none;
        border-radius: 10px;
        font-weight: bold;
        cursor: pointer;
      }
      .btn:hover {
        background: #ffb870;
      }
      .ratio-buttons {
        display: flex;
        gap: 0.5rem;
        margin: 1rem 0;
      }
      .ratio-buttons button {
        padding: 0.5rem 1rem;
        background: #333;
        border: 1px solid #666;
        color: white;
        border-radius: 6px;
        cursor: pointer;
      }
      .ratio-buttons button:hover {
        background: #555;
      }
    </style>
  </head>

  <body>
    <section class="page">

      <h1>Nový článek</h1>

      <form method="post" action="/api/create-post" enctype="multipart/form-data" class="form">

        <label>
          Název článku
          <input type="text" name="title" required>
        </label>

        <label>
          Krátký popis
          <input type="text" name="description" required>
        </label>

        <label>
          Datum
          <input type="date" name="date" required>
        </label>

        <label>
          Sekce
          <select name="section_id" id="section-select" required>
            <option value="">Načítám…</option>
          </select>
        </label>

        <label>
          Podsekce
          <select name="subsection_id" id="subsection-select">
            <option value="">(volitelné)</option>
          </select>
        </label>

        <label>
          Obsah článku
          <textarea name="content" rows="10" required></textarea>
        </label>

        <label>
          Fotka (cover)
          <input type="file" id="photo-input" accept="image/*">
        </label>

        <div id="editor" style="display:none; margin-top:20px;">
          <h3>Editor fotky</h3>

          <div class="ratio-buttons">
            <button type="button" data-ratio="4/3">4:3</button>
            <button type="button" data-ratio="3/4">3:4</button>
            <button type="button" data-ratio="1/1">1:1</button>
            <button type="button" data-ratio="16/9">16:9</button>
            <button type="button" data-ratio="free">Volně</button>
          </div>

          <img id="photo-preview" style="max-width:100%; border-radius:10px;" />

          <button type="button" id="crop-btn" class="btn" style="margin-top:1rem;">
            Použít ořez
          </button>
        </div>

        <input type="file" id="final-photo" name="photos" style="display:none;">

        <button type="submit" class="btn">Publikovat článek</button>

      </form>

    </section>

    <script>
      /* 1) Načtení číselníků z API */
      async function loadSections() {
        const res = await fetch("/api/sections");
        const { sections, subsections } = await res.json();

        const sectionSelect = document.getElementById("section-select");
        const subsectionSelect = document.getElementById("subsection-select");

        sectionSelect.innerHTML = `<option value="">Vyber sekci…</option>`;

        sections.forEach(s => {
          sectionSelect.innerHTML += `<option value="${s.id}">${s.name}</option>`;
        });

        sectionSelect.addEventListener("change", () => {
          const id = Number(sectionSelect.value);
          const filtered = subsections.filter(ss => ss.section_id === id);

          subsectionSelect.innerHTML = `<option value="">(volitelné)</option>`;
          filtered.forEach(ss => {
            subsectionSelect.innerHTML += `<option value="${ss.id}">${ss.name}</option>`;
          });
        });
      }

      loadSections();


      /* 2) Editor fotek */
      let cropper = null;

      document.getElementById("photo-input").addEventListener("change", (e) => {
        const file = e.target.files[0];
        if (!file) return;

        const preview = document.getElementById("photo-preview");
        const editor = document.getElementById("editor");

        preview.src = URL.createObjectURL(file);
        editor.style.display = "block";

        if (cropper) cropper.destroy();

        cropper = new Cropper(preview, {
          aspectRatio: 4 / 3,
          viewMode: 1,
          movable: true,
          zoomable: true,
          rotatable: true,
          scalable: true
        });
      });

      /* 3) Přepínání poměrů stran */
      document.querySelectorAll(".ratio-buttons button").forEach(btn => {
        btn.addEventListener("click", () => {
          const r = btn.dataset.ratio;
          if (r === "free") cropper.setAspectRatio(NaN);
          else cropper.setAspectRatio(eval(r));
        });
      });

      /* 4) Ořez a příprava pro upload */
      document.getElementById("crop-btn").addEventListener("click", () => {
        const canvas = cropper.getCroppedCanvas({
          width: 2000,
          height: 2000
        });

        canvas.toBlob((blob) => {
          const fileInput = document.getElementById("final-photo");
          const file = new File([blob], "cover.jpg", { type: "image/jpeg" });

          const dt = new DataTransfer();
          dt.items.add(file);
          fileInput.files = dt.files;

          alert("Fotka upravena a připravena k nahrání.");
        }, "image/jpeg", 0.9);
      });
    </script>

  </body>
</html>
