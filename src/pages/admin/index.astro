---
const error = Astro.url.searchParams.get("error");
---

<html lang="cs">
  <head>
    <title>Přihlášení do administrace</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
      body { background:#0b0c10; color:#e5e5e5; font-family:system-ui; padding:20px; margin:0; display:flex; justify-content:center; align-items:center; height:100vh; }
      .box { background:#111827; padding:30px; border-radius:10px; width:100%; max-width:350px; }
      label { display:block; margin-bottom:6px; font-size:14px; }
      input {
        width:100%; padding:10px; margin-bottom:15px;
        border-radius:6px; border:1px solid #1f2937;
        background:#020617; color:white;
      }
      .btn { width:100%; padding:10px; border-radius:6px; border:none; cursor:pointer; font-weight:600; }
      .btn-primary { background:#22c55e; color:#0b0c10; }
      .btn-primary:hover { background:#16a34a; }
      .error { color:#fca5a5; margin-bottom:10px; }
    </style>
  </head>
  <body>

    <div class="box">
      <h2>Přihlášení</h2>

      {error && <div class="error">Špatné jméno nebo heslo</div>}

      <label>Uživatel</label>
      <input type="text" id="username">

      <label>Heslo</label>
      <input type="password" id="password">

      <button class="btn btn-primary" onclick="login()">Přihlásit se</button>
    </div>

    <script>
      async function login() {
        const username = document.getElementById("username").value.trim();
        const password = document.getElementById("password").value.trim();

        const res = await fetch("/api/admin/login", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ username, password })
        });

        if (!res.ok) {
          window.location.href = "/admin/?error=1";
          return;
        }

        const data = await res.json();
        localStorage.setItem("adminToken", data.token);

        window.location.href = "/admin/articles.html";
      }
    </script>

  </body>
</html>
