---
import { getArticles } from "../../utils/adminApi";

const articles = await getArticles();
---

<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <title>Admin – Správa článků</title>
    <style>
      body {
        background: #0d0d0f;
        color: #e8e8e8;
        font-family: Inter, sans-serif;
        padding: 2rem;
      }

      h1 {
        margin-bottom: 1rem;
      }

      .panel {
        background: #16161a;
        padding: 1.5rem;
        border-radius: 10px;
        margin-bottom: 2rem;
      }

      input, textarea {
        width: 100%;
        padding: 0.7rem;
        margin-top: 0.5rem;
        margin-bottom: 1rem;
        border-radius: 8px;
        border: none;
        background: #1f1f24;
        color: #fff;
      }

      button {
        background: #4cc9f0;
        border: none;
        padding: 0.8rem 1.5rem;
        border-radius: 8px;
        cursor: pointer;
        transition: 0.2s;
      }

      button:hover {
        background: #3bb8e0;
      }

      .list-item {
        padding: 1rem;
        background: #1a1a1f;
        border-radius: 8px;
        margin-bottom: 0.5rem;
      }
    </style>
  </head>

  <body>
    <h1>Admin – Správa článků</h1>

    <div class="panel">
      <h2>Vytvořit nový článek</h2>

      <form id="articleForm">
        <label>Název článku</label>
        <input type="text" id="title" required />

        <label>Obsah</label>
        <textarea id="content" rows="6" required></textarea>

        <label>Fotky</label>
        <input type="file" id="photos" multiple accept="image/*" />

        <button type="submit">Uložit článek</button>
      </form>
    </div>

    <div class="panel">
      <h2>Existující články</h2>

      {articles.map((a) => (
        <div class="list-item">
          <strong>{a.title}</strong><br />
          <small>{a.file}</small>
        </div>
      ))}
    </div>

    <script>
      document.getElementById("articleForm").addEventListener("submit", async (e) => {
        e.preventDefault();

        const formData = new FormData();
        formData.append("title", document.getElementById("title").value);
        formData.append("content", document.getElementById("content").value);

        const photos = document.getElementById("photos").files;
        for (let i = 0; i < photos.length; i++) {
          formData.append("photos", photos[i]);
        }

        await fetch("/api/admin/save", {
          method: "POST",
          body: formData
        });

        alert("Článek uložen");
        location.reload();
      });
    </script>
  </body>
</html>
