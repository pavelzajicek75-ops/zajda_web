---
import AdminLayout from "../../layouts/AdminLayout.astro";
import articles from "../../data/articles.json";
---

<AdminLayout title="Seznam článků">
  <h1>Seznam článků</h1>

  <table>
    <thead>
      <tr>
        <th>Obrázek</th>
        <th>Název</th>
        <th>Datum</th>
        <th>ID</th>
        <th>Akce</th>
      </tr>
    </thead>

    <tbody>
      {articles.map(article => (
        <tr>
          <td>
            <img 
              src={article.image || "/admin/no-image.png"} 
              style="width:80px;height:50px;object-fit:cover;border-radius:6px;" 
            />
          </td>

          <td>{article.title}</td>
          <td>{article.date}</td>
          <td>{article.id}</td>

          <td>
            <a 
              href={`/admin/edit?id=${article.id}`} 
              class="btn-edit"
            >
              Upravit
            </a>

            <a 
              href={`/admin/delete?id=${article.id}`} 
              class="btn-delete"
            >
              Smazat
            </a>
          </td>
        </tr>
      ))}
    </tbody>
  </table>

  <style>
    h1 {
      margin-bottom: 20px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: #1a1a1a;
      border-radius: 8px;
      overflow: hidden;
    }

    th, td {
      padding: 12px;
      border-bottom: 1px solid #333;
      text-align: left;
      color: #ddd;
    }

    th {
      background: #222;
      font-weight: bold;
    }

    tr:hover {
      background: #2a2a2a;
    }

    .btn-edit {
      padding: 6px 10px;
      background: #4a90e2;
      color: white;
      border-radius: 4px;
      text-decoration: none;
      margin-right: 6px;
    }

    .btn-delete {
      padding: 6px 10px;
      background: #b30000;
      color: white;
      border-radius: 4px;
      text-decoration: none;
    }
  </style>
</AdminLayout>
