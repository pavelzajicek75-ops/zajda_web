---
import AdminLayout from "../../layouts/AdminLayout.astro";
import articles from "../../data/articles.json";

const id = Astro.url.searchParams.get("id");
let article = null;

if (id) {
  article = articles.find(a => a.id === Number(id));
}
---

<AdminLayout title="Upravit článek">

  {id && article ? (
    <>
      <h1>Upravit článek: {article.title}</h1>

      <form id="editForm">
        <label>Název</label>
        <input type="text" id="title" value={article.title} />

        <label>Datum</label>
        <input type="date" id="date" value={article.date} />

        <label>Obsah</label>
        <textarea id="content" rows="12">{article.content}</textarea>

        <button type="button" onclick="saveArticle()">Uložit změny</button>
      </form>
    </>
  ) : (
    <p style="color:#aaa;">Nebyl vybrán žádný článek. Otevři editor přes seznam článků.</p>
  )}

  <style>
    form {
      display: flex;
      flex-direction: column;
      gap: 15px;
      max-width: 700px;
    }

    input, textarea {
      padding: 12px;
      border-radius: 8px;
      border: 1px solid #444;
      background: #1e1e1e;
      color: white;
      font-size: 16px;
    }

    button {
      padding: 12px;
      background: #4a90e2;
      border: none;
      border-radius: 8px;
      color: white;
      font-size: 16px;
      cursor: pointer;
      margin-top: 10px;
    }

    button:hover {
      background: #357ac8;
    }
  </style>

  <script>
    async function saveArticle() {
      const token = localStorage.getItem("admin_token");

      const body = {
        id: "{id}",
        title: document.getElementById("title").value,
        date: document.getElementById("date").value,
        content: document.getElementById("content").value
      };

      const res = await fetch("/api/admin/save", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Authorization": "Bearer " + token
        },
        body: JSON.stringify(body)
      });

      const data = await res.json();

      if (data.success) {
        alert("Článek uložen");
        window.location.href = "/admin/articles";
      } else {
        alert("Chyba při ukládání");
      }
    }
  </script>

</AdminLayout>
