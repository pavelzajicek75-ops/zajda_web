---
import { Astro } from 'astro';
---

<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <title>Seznam článků</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body {
            background: #0d0d0d;
            color: #e6e6e6;
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 20px;
        }

        h1 {
            margin-bottom: 20px;
        }

        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .btn {
            background: #4a90e2;
            padding: 10px 16px;
            border-radius: 6px;
            color: white;
            text-decoration: none;
            font-weight: bold;
        }

        .article-card {
            background: #1a1a1a;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 15px;
            display: flex;
            gap: 15px;
            align-items: center;
        }

        .article-card img {
            width: 120px;
            height: 80px;
            object-fit: cover;
            border-radius: 6px;
        }

        .article-info {
            flex: 1;
        }

        .actions {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .btn-small {
            padding: 6px 10px;
            background: #333;
            border-radius: 4px;
            text-align: center;
            color: white;
            text-decoration: none;
        }

        .btn-delete {
            background: #b30000;
        }
    </style>
</head>
<body>

<div class="top-bar">
    <h1>Seznam článků</h1>
    <a class="btn" href="/admin/novyclanek/">+ Nový článek</a>
</div>

<div id="articles"></div>

<script>
async function loadArticles() {
    try {
        const response = await fetch('/data/articles.json');
        const articles = await response.json();

        const container = document.getElementById('articles');
        container.innerHTML = '';

        articles.forEach(article => {
            const card = document.createElement('div');
            card.className = 'article-card';

            const img = document.createElement('img');
            img.src = article.image || '/admin/no-image.png';

            const info = document.createElement('div');
            info.className = 'article-info';
            info.innerHTML = `
                <h3>${article.title}</h3>
                <p>${article.date}</p>
            `;

            const actions = document.createElement('div');
            actions.className = 'actions';

            const editBtn = document.createElement('a');
            editBtn.className = 'btn-small';
            editBtn.href = '/admin/edit?id=' + article.id;
            editBtn.textContent = 'Upravit';

            const deleteBtn = document.createElement('a');
            deleteBtn.className = 'btn-small btn-delete';
            deleteBtn.href = '#';
            deleteBtn.textContent = 'Smazat';
            deleteBtn.onclick = () => deleteArticle(article.id);

            actions.appendChild(editBtn);
            actions.appendChild(deleteBtn);

            card.appendChild(img);
            card.appendChild(info);
            card.appendChild(actions);

            container.appendChild(card);
        });

    } catch (err) {
        console.error('Chyba při načítání článků:', err);
    }
}

async function deleteArticle(id) {
    if (!confirm('Opravdu smazat článek?')) return;

    const response = await fetch('/api/admin/delete?id=' + id, {
        method: 'POST'
    });

    if (response.ok) {
        alert('Článek smazán');
        loadArticles();
    } else {
        alert('Chyba při mazání');
    }
}

loadArticles();
</script>

</body>
</html>
