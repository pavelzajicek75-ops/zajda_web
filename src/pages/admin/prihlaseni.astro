<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <title>Test login</title>
    <style>
      /* Zruš jakýkoli globální blok tlačítek */
      button {
        pointer-events: auto !important;
        opacity: 1 !important;
        cursor: pointer !important;
      }

      #click-overlay-test {
        margin-top: 20px;
        padding: 10px;
        background: #222;
        color: #fff;
      }
    </style>
  </head>
  <body style="background:#111;color:#fff;font-family:sans-serif;padding:40px;">
    <h1>TEST: tlačítko</h1>

    <button
      id="testBtn"
      type="button"
      onclick="alert('INLINE KLIK FUNGUJE');"
      style="padding:12px 20px;background:#4a90e2;border:none;color:white;font-size:16px;"
    >
      TEST TLAČÍTKO
    </button>

    <div id="click-overlay-test">
      Pokud se po kliku neukáže alert, něco ti krade kliky (overlay / iframe / div nad tím).
    </div>

    <script>
      console.log("JS ve stránce JE načtený");

      const btn = document.getElementById("testBtn");
      console.log("Našel jsem tlačítko?", !!btn);

      btn.addEventListener("click", () => {
        console.log("EVENT LISTENER KLIK FUNGUJE");
      });
    </script>
  </body>
</html>
