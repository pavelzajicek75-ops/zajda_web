---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Přihlášení" noAuth={true}>
  <h1>Přihlášení</h1>

  <p>Login přes server (Cloudflare Worker + JWT).</p>

  <form
    id="loginForm"
    style="display:flex;flex-direction:column;gap:12px;max-width:320px;margin-top:20px;"
    onsubmit="return false;"
  >
    <label for="username">Uživatel</label>
    <input
      type="text"
      id="username"
      autocomplete="username"
      style="padding:10px;border-radius:4px;border:1px solid #444;background:#222;color:#fff;"
    />

    <label for="password">Heslo</label>
    <input
      type="password"
      id="password"
      autocomplete="current-password"
      style="padding:10px;border-radius:4px;border:1px solid #444;background:#222;color:#fff;"
    />

    <button
      type="button"
      id="loginBtn"
      style="margin-top:10px;padding:10px 16px;background:#4a90e2;border:none;border-radius:4px;color:white;font-weight:600;font-size:15px;pointer-events:auto;opacity:1;cursor:pointer;position:relative;z-index:9999;"
    >
      Přihlásit
    </button>
  </form>

  <div id="loginMessage" style="margin-top:16px;color:#f66;"></div>

  <script>
    console.log("Login stránka – JS běží");

    const btn = document.getElementById("loginBtn");
    const userInput = document.getElementById("username");
    const passInput = document.getElementById("password");
    const msg = document.getElementById("loginMessage");

    btn.addEventListener("click", async () => {
      msg.style.color = "#f66";
      msg.textContent = "Přihlašuji…";

      const username = userInput.value.trim();
      const password = passInput.value.trim();

      if (!username || !password) {
        msg.textContent = "Vyplň uživatele i heslo.";
        return;
      }

      try {
        const res = await fetch("/api/admin/login", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ username, password }),
        });

        const data = await res.json();

        if (!res.ok) {
          msg.textContent = data.error || "Chyba přihlášení.";
          return;
        }

        localStorage.setItem("admin_token", data.token);
        msg.style.color = "#6f6";
        msg.textContent = "Přihlášení OK, přesměrovávám…";

        setTimeout(() => {
          window.location.href = "/admin";
        }, 700);
      } catch (e) {
        console.error(e);
        msg.textContent = "Chyba spojení se serverem.";
      }
    });
  </script>
</AdminLayout>
