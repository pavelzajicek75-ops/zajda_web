---
const cards = [
  {
    title: "Cestování",
    text: "Moje cesty, deníky, fotky a příběhy z míst, která mě formují.",
    link: "/cestovani",
    icon: "🌍"
  },
  {
    title: "Fotografie",
    text: "Výběr mých nejlepších fotek. Momentky, krajiny, detaily.",
    link: "/foto",
    icon: "📸"
  },
  {
    title: "Blog",
    text: "Osobní články, myšlenky, projekty a životní poznámky.",
    link: "/blog",
    icon: "✍️"
  },
  {
    title: "O mně",
    text: "Kdo jsem, co dělám a proč tvořím tenhle vesmír.",
    link: "/o-mne",
    icon: "👤"
  }
];
---

<h1 class="title fade-in">Moje diagnóza: můj vesmír</h1>

<div class="cards">
  {cards.map((card, i) => (
    <a href={card.link} class={`card fly-in-${i}`}>
      <div class="icon">{card.icon}</div>
      <h3>{card.title}</h3>
      <p>{card.text}</p>
      <span class="btn">Otevřít</span>
    </a>
  ))}
</div>

<style>
  body {
    background: #0b0b0b;
    color: #e6e6e6;
    font-family: system-ui, sans-serif;
  }

  .title {
    text-align: center;
    margin-top: 2rem;
    font-size: 2.6rem;
    color: #fff;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.8s ease forwards;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.8rem;
    padding: 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .card {
    background: #111;
    border: 1px solid #222;
    padding: 1.7rem;
    border-radius: 18px;
    text-decoration: none;
    color: #eee;
    transition: 0.25s;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    opacity: 0;
    transform: translateY(30px);
  }

  .card:hover {
    border-color: #4a90e2;
    transform: translateY(-6px);
  }

  .icon {
    font-size: 2.8rem;
  }

  h3 {
    margin: 0;
    font-size: 1.5rem;
  }

  p {
    opacity: 0.85;
    line-height: 1.45;
  }

  .btn {
    margin-top: auto;
    background: #4a90e2;
    padding: 0.7rem 1rem;
    border-radius: 10px;
    text-align: center;
    font-weight: 600;
    color: white;
  }

  .btn:hover {
    background: #357ab8;
  }

  /* Animace */
  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes flyIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fly-in-0 { animation: flyIn 0.6s ease forwards 0.2s; }
  .fly-in-1 { animation: flyIn 0.6s ease forwards 0.35s; }
  .fly-in-2 { animation: flyIn 0.6s ease forwards 0.5s; }
  .fly-in-3 { animation: flyIn 0.6s ease forwards 0.65s; }
</style>
