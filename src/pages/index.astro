---
const cards = [
  {
    title: "Cestování",
    text: "Moje cesty, deníky, fotky a příběhy z míst, která mě formují.",
    link: "/cestovani",
    icon: "🌍"
  },
  {
    title: "Fotografie",
    text: "Výběr mých nejlepších fotek. Momentky, krajiny, detaily.",
    link: "/foto",
    icon: "📸"
  },
  {
    title: "Blog",
    text: "Osobní články, myšlenky, projekty a životní poznámky.",
    link: "/blog",
    icon: "✍️"
  },
  {
    title: "O mně",
    text: "Kdo jsem, co dělám a proč tvořím tenhle vesmír.",
    link: "/o-mne",
    icon: "👤"
  }
];
---

<!-- PARALLAX / BACKGROUND VRSTVY -->
<div class="bg-layer starfield parallax-layer" data-depth="0.1"></div>
<div class="bg-layer nebula parallax-layer" data-depth="0.2"></div>
<div class="bg-layer galaxy parallax-layer" data-depth="0.3"></div>
<div class="bg-layer shooting-stars"></div>

<section class="hero">
  <h1 class="title">Moje diagnóza: můj vesmír</h1>
  <p class="subtitle">Osobní prostor, kde tvořím, cestuji, fotím a žiju.</p>
</section>

<div class="cards">
  {cards.map((card, i) => (
    <a href={card.link} class={`card fly-in-${i}`}>
      <div class="icon pulse">{card.icon}</div>
      <h3>{card.title}</h3>
      <p>{card.text}</p>
      <span class="btn">Otevřít</span>
    </a>
  ))}
</div>

<!-- PARALLAX SCRIPT (myš) -->
<script>
  if (typeof window !== "undefined") {
    const layers = document.querySelectorAll(".parallax-layer");
    window.addEventListener("mousemove", (e) => {
      const x = (e.clientX / window.innerWidth - 0.5) * 2;
      const y = (e.clientY / window.innerHeight - 0.5) * 2;
      layers.forEach((layer) => {
        const depth = parseFloat(layer.getAttribute("data-depth") || "0");
        const translateX = -x * depth * 30;
        const translateY = -y * depth * 30;
        layer.style.transform = `translate3d(${translateX}px, ${translateY}px, 0)`;
      });
    });
  }
</script>

<style>
  :root {
    color-scheme: dark;
  }

  body {
    margin: 0;
    font-family: system-ui, sans-serif;
    color: #e6e6e6;
    background: #02030a;
    overflow-x: hidden;
    position: relative;
    min-height: 100vh;
  }

  /* ===========================
     BACKGROUND VRSTVY
  =========================== */

  .bg-layer {
    position: fixed;
    inset: -20%;
    pointer-events: none;
    z-index: -10;
  }

  /* HVĚZDNÉ POZADÍ – dvě vrstvy hvězd */
  .starfield {
    background-image:
      radial-gradient(2px 2px at 10% 20%, rgba(255,255,255,0.8) 0, transparent 60%),
      radial-gradient(1.5px 1.5px at 80% 30%, rgba(255,255,255,0.6) 0, transparent 60%),
      radial-gradient(1.5px 1.5px at 30% 80%, rgba(255,255,255,0.5) 0, transparent 60%),
      radial-gradient(2px 2px at 60% 60%, rgba(255,255,255,0.7) 0, transparent 60%);
    background-color: #02030a;
    animation: starDrift 120s linear infinite;
    opacity: 0.7;
  }

  @keyframes starDrift {
    from { transform: translate3d(0,0,0); }
    to   { transform: translate3d(-400px,-400px,0); }
  }

  /* BAREVNÉ MLHOVINY – nebula */
  .nebula {
    background:
      radial-gradient(circle at 20% 20%, rgba(120,80,255,0.35), transparent 60%),
      radial-gradient(circle at 80% 70%, rgba(0,200,255,0.25), transparent 60%),
      radial-gradient(circle at 50% 40%, rgba(255,80,180,0.25), transparent 65%);
    mix-blend-mode: screen;
    opacity: 0.7;
    animation: nebulaFloat 40s ease-in-out infinite alternate;
  }

  @keyframes nebulaFloat {
    from { transform: translate3d(0,0,0) scale(1); }
    to   { transform: translate3d(40px,-30px,0) scale(1.05); }
  }

  /* POMALU ROTUJÍCÍ GALAXIE */
  .galaxy {
    background:
      radial-gradient(circle at 50% 50%, rgba(255,255,255,0.9) 0, rgba(255,255,255,0.1) 8%, transparent 40%),
      radial-gradient(circle at 50% 50%, rgba(120,180,255,0.4) 0, transparent 55%);
    opacity: 0.25;
    transform-origin: center;
    animation: galaxySpin 160s linear infinite;
  }

  @keyframes galaxySpin {
    from { transform: rotate(0deg) scale(1.1); }
    to   { transform: rotate(360deg) scale(1.1); }
  }

  /* PADAJÍCÍ HVĚZDY – shooting stars */
  .shooting-stars {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -5;
    overflow: hidden;
  }

  .shooting-stars::before,
  .shooting-stars::after {
    content: "";
    position: absolute;
    top: -10%;
    left: 120%;
    width: 2px;
    height: 120px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.9), transparent);
    opacity: 0.8;
    transform: rotate(-35deg);
    animation: shooting 6s linear infinite;
  }

  .shooting-stars::after {
    animation-delay: 3s;
    left: 100%;
    top: -5%;
  }

  @keyframes shooting {
    0% {
      transform: translate3d(0,0,0) rotate(-35deg);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    40% {
      transform: translate3d(-800px, 400px, 0) rotate(-35deg);
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }

  /* ===========================
     HERO
  =========================== */

  .hero {
    text-align: center;
    padding: 4rem 1rem 2rem;
  }

  .title {
    font-size: 3rem;
    font-weight: 700;
    opacity: 0;
    transform: translateY(30px);
    animation: fadeUp 1s ease forwards;
    text-shadow: 0 0 18px rgba(0,0,0,0.8);
  }

  .subtitle {
    margin-top: 0.5rem;
    font-size: 1.2rem;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 1s ease forwards 0.4s;
    color: #b0b0b0;
    text-shadow: 0 0 12px rgba(0,0,0,0.8);
  }

  /* ===========================
     GRID KARET
  =========================== */

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
    padding: 2rem;
    max-width: 1100px;
    margin: 0 auto 4rem;
  }

  .card {
    background: rgba(10, 10, 20, 0.9);
    border: 1px solid rgba(80, 120, 255, 0.25);
    padding: 1.8rem;
    border-radius: 20px;
    text-decoration: none;
    color: #eee;
    transition: 0.25s;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    opacity: 0;
    transform: translateY(40px) scale(0.97);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(10px);
  }

  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top right, rgba(74,144,226,0.25), transparent 70%);
    opacity: 0;
    transition: 0.4s;
  }

  .card:hover::before {
    opacity: 1;
  }

  .card:hover {
    border-color: #4a90e2;
    transform: translateY(-6px) scale(1.03);
    box-shadow: 0 0 25px rgba(74, 144, 226, 0.35);
  }

  .icon {
    font-size: 3rem;
    transition: 0.3s ease;
  }

  .card:hover .icon {
    transform: translateY(-6px) scale(1.12);
  }

  .pulse {
    animation: pulse 3s ease-in-out infinite;
  }

  h3 {
    margin: 0;
    font-size: 1.6rem;
  }

  p {
    opacity: 0.9;
    line-height: 1.45;
  }

  .btn {
    margin-top: auto;
    background: #4a90e2;
    padding: 0.7rem 1rem;
    border-radius: 10px;
    text-align: center;
    font-weight: 600;
    color: white;
    transition: 0.2s;
  }

  .btn:hover {
    background: #357ab8;
    transform: scale(1.05);
  }

  /* ===========================
     ANIMACE ELEMENTŮ
  =========================== */

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.08); opacity: 0.9; }
  }

  @keyframes flyIn {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .fly-in-0 { animation: flyIn 0.7s ease forwards 0.2s; }
  .fly-in-1 { animation: flyIn 0.7s ease forwards 0.35s; }
  .fly-in-2 { animation: flyIn 0.7s ease forwards 0.5s; }
  .fly-in-3 { animation: flyIn 0.7s ease forwards 0.65s; }

  /* RESPONSIVE */
  @media (max-width: 600px) {
    .title {
      font-size: 2.3rem;
    }
    .subtitle {
      font-size: 1rem;
    }
  }
</style>
