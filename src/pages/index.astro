---
const cards = [
  {
    title: "Cestování",
    text: "Moje cesty, deníky, fotky a příběhy z míst, která mě formují.",
    link: "/cestovani",
    icon: "🌍"
  },
  {
    title: "Fotografie",
    text: "Výběr mých nejlepších fotek. Momentky, krajiny, detaily.",
    link: "/foto",
    icon: "📸"
  },
  {
    title: "Blog",
    text: "Osobní články, myšlenky, projekty a životní poznámky.",
    link: "/blog",
    icon: "✍️"
  },
  {
    title: "O mně",
    text: "Kdo jsem, co dělám a proč tvořím tenhle vesmír.",
    link: "/o-mne",
    icon: "👤"
  }
];
---

<section class="hero">
  <h1 class="title">Moje diagnóza: můj vesmír</h1>
  <p class="subtitle">Osobní prostor, kde tvořím, cestuji, fotím a žiju.</p>
</section>

<div class="cards">
  {cards.map((card, i) => (
    <a href={card.link} class={`card fly-in-${i}`}>
      <div class="icon">{card.icon}</div>
      <h3>{card.title}</h3>
      <p>{card.text}</p>
      <span class="btn">Otevřít</span>
    </a>
  ))}
</div>

<style>
  :root {
    color-scheme: dark;
  }

  body {
    margin: 0;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: radial-gradient(circle at 50% 0%, #181824, #0c0c14 60%, #05050a 100%);
    color: #e6e6e6;
    overflow-x: hidden;
  }

  /* HERO */

  .hero {
    text-align: center;
    padding: 4rem 1rem 2rem;
  }

  .title {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    opacity: 0;
    transform: translateY(24px);
    animation: fadeUp 0.8s ease forwards;
  }

  .subtitle {
    margin-top: 0.6rem;
    font-size: 1.15rem;
    color: #a8a8b5;
    opacity: 0;
    transform: translateY(18px);
    animation: fadeUp 0.8s ease forwards 0.25s;
  }

  /* GRID KARET */

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.8rem;
    padding: 2.5rem 2rem 4rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .card {
    background: rgba(20, 20, 30, 0.96);
    border-radius: 18px;
    border: 1px solid #26263a;
    padding: 1.7rem;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    opacity: 0;
    transform: translateY(26px);
    position: relative;
    overflow: hidden;
  }

  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top right, rgba(90,140,255,0.18), transparent 65%);
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }

  .card:hover {
    border-color: #4a90e2;
    transform: translateY(-6px);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.55);
  }

  .card:hover::before {
    opacity: 1;
  }

  .icon {
    font-size: 2.6rem;
  }

  h3 {
    margin: 0;
    font-size: 1.5rem;
  }

  p {
    margin: 0;
    opacity: 0.85;
    line-height: 1.45;
  }

  .btn {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    padding: 0.55rem 1.1rem;
    border-radius: 999px;
    background: #4a90e2;
    color: #fff;
    font-weight: 600;
    font-size: 0.9rem;
    margin-top: 1.1rem;
    transition: background 0.2s ease, transform 0.15s ease;
  }

  .btn:hover {
    background: #357ab8;
    transform: translateY(-1px);
  }

  /* ANIMACE */

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes flyIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fly-in-0 { animation: flyIn 0.6s ease forwards 0.25s; }
  .fly-in-1 { animation: flyIn 0.6s ease forwards 0.35s; }
  .fly-in-2 { animation: flyIn 0.6s ease forwards 0.45s; }
  .fly-in-3 { animation: flyIn 0.6s ease forwards 0.55s; }

  /* RESPONSIVE */

  @media (max-width: 700px) {
    .title {
      font-size: 2.3rem;
    }
    .subtitle {
      font-size: 1rem;
    }
    .cards {
      padding-inline: 1.4rem;
    }
  }
</style>
