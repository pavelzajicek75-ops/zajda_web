---
const cards = [
  {
    title: "Cestování",
    text: "Moje cesty, deníky, fotky a příběhy z míst, která mě formují.",
    link: "/cestovani",
    icon: "🌍"
  },
  {
    title: "Fotografie",
    text: "Výběr mých nejlepších fotek. Momentky, krajiny, detaily.",
    link: "/foto",
    icon: "📸"
  },
  {
    title: "Blog",
    text: "Osobní články, myšlenky, projekty a životní poznámky.",
    link: "/blog",
    icon: "✍️"
  },
  {
    title: "O mně",
    text: "Kdo jsem, co dělám a proč tvořím tenhle vesmír.",
    link: "/o-mne",
    icon: "👤"
  }
];
---

<section class="hero">
  <h1 class="title fly-title">Moje diagnóza: můj vesmír</h1>
  <p class="subtitle fade-sub">Osobní prostor, kde tvořím, cestuji, fotím a žiju.</p>
</section>

<div class="cards">
  {cards.map((card, i) => (
    <a href={card.link} class={`card fly-in-${i}`}>
      <div class="icon pulse">{card.icon}</div>
      <h3>{card.title}</h3>
      <p>{card.text}</p>
      <span class="btn">Otevřít</span>
    </a>
  ))}
</div>

<style>
  /* -----------------------------------------
     ANIMACE POZADÍ – gradient wave
  ----------------------------------------- */
  body {
    background: linear-gradient(120deg, #050505, #0f0f0f, #050505);
    background-size: 300% 300%;
    animation: gradientMove 12s ease infinite;
    color: #e6e6e6;
    font-family: system-ui, sans-serif;
    overflow-x: hidden;
  }

  @keyframes gradientMove {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* -----------------------------------------
     HERO
  ----------------------------------------- */
  .hero {
    text-align: center;
    padding: 4rem 1rem 2rem;
  }

  .title {
    font-size: 3rem;
    font-weight: 700;
    opacity: 0;
    transform: translateY(30px);
    animation: fadeUp 1s ease forwards;
  }

  .subtitle {
    margin-top: 0.5rem;
    font-size: 1.2rem;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 1s ease forwards 0.4s;
    color: #aaa;
  }

  /* -----------------------------------------
     GRID KARET
  ----------------------------------------- */
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
    padding: 2rem;
    max-width: 1100px;
    margin: 0 auto 4rem;
  }

  /* -----------------------------------------
     KARTA
  ----------------------------------------- */
  .card {
    background: rgba(20, 20, 20, 0.85);
    border: 1px solid #222;
    padding: 1.8rem;
    border-radius: 20px;
    text-decoration: none;
    color: #eee;
    transition: 0.25s;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    opacity: 0;
    transform: translateY(40px) scale(0.97);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(6px);
  }

  /* Hover efekty */
  .card:hover {
    border-color: #4a90e2;
    transform: translateY(-6px) scale(1.03);
    box-shadow: 0 0 25px rgba(74, 144, 226, 0.25);
  }

  /* Glow efekt */
  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top right, rgba(74,144,226,0.18), transparent 70%);
    opacity: 0;
    transition: 0.4s;
  }

  .card:hover::before {
    opacity: 1;
  }

  /* Ikona */
  .icon {
    font-size: 3rem;
    transition: 0.3s ease;
  }

  /* Parallax efekt */
  .card:hover .icon {
    transform: translateY(-6px) scale(1.12);
  }

  /* Pulzování ikon */
  .pulse {
    animation: pulse 3s ease-in-out infinite;
  }

  /* Texty */
  h3 {
    margin: 0;
    font-size: 1.6rem;
  }

  p {
    opacity: 0.85;
    line-height: 1.45;
  }

  /* Tlačítko */
  .btn {
    margin-top: auto;
    background: #4a90e2;
    padding: 0.7rem 1rem;
    border-radius: 10px;
    text-align: center;
    font-weight: 600;
    color: white;
    transition: 0.2s;
  }

  .btn:hover {
    background: #357ab8;
    transform: scale(1.05);
  }

  /* -----------------------------------------
     ANIMACE ELEMENTŮ
  ----------------------------------------- */
  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.08); opacity: 0.9; }
  }

  @keyframes flyIn {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .fly-in-0 { animation: flyIn 0.7s ease forwards 0.2s; }
  .fly-in-1 { animation: flyIn 0.7s ease forwards 0.35s; }
  .fly-in-2 { animation: flyIn 0.7s ease forwards 0.5s; }
  .fly-in-3 { animation: flyIn 0.7s ease forwards 0.65s; }

</style>
