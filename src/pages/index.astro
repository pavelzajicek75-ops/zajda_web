---
const cards = [
  {
    title: "Cestování",
    text: "Moje cesty, deníky, fotky a příběhy z míst, která mě formují.",
    link: "/cestovani",
    icon: "🌍"
  },
  {
    title: "Fotografie",
    text: "Výběr mých nejlepších fotek. Momentky, krajiny, detaily.",
    link: "/foto",
    icon: "📸"
  },
  {
    title: "Blog",
    text: "Osobní články, myšlenky, projekty a životní poznámky.",
    link: "/blog",
    icon: "✍️"
  },
  {
    title: "O mně",
    text: "Kdo jsem, co dělám a proč tvořím tenhle vesmír.",
    link: "/o-mne",
    icon: "👤"
  }
];
---

<h1 class="title">Moje diagnóza: můj vesmír</h1>

<div class="cards">
  {cards.map(card => (
    <a href={card.link} class="card">
      <div class="icon">{card.icon}</div>
      <h3>{card.title}</h3>
      <p>{card.text}</p>
      <span class="btn">Otevřít</span>
    </a>
  ))}
</div>

<style>
  body {
    background: #0d0d0d;
    color: #e6e6e6;
    font-family: system-ui, sans-serif;
  }

  .title {
    text-align: center;
    margin-top: 2rem;
    font-size: 2.4rem;
    color: #fff;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    padding: 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .card {
    background: #111;
    border: 1px solid #222;
    padding: 1.5rem;
    border-radius: 16px;
    text-decoration: none;
    color: #eee;
    transition: 0.2s;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .card:hover {
    border-color: #4a90e2;
    transform: translateY(-4px);
  }

  .icon {
    font-size: 2.5rem;
  }

  h3 {
    margin: 0;
    font-size: 1.4rem;
  }

  p {
    opacity: 0.8;
    line-height: 1.4;
  }

  .btn {
    margin-top: auto;
    background: #4a90e2;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    text-align: center;
    font-weight: 600;
    color: white;
  }

  .btn:hover {
    background: #357ab8;
  }
</style>
