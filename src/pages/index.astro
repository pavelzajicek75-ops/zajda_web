---
const quotes = [
  "A light you can’t always see.",
  "We get lost to find ourselves.",
  "Stars fall, but we rise.",
  "Where the night meets the soul.",
  "Every breath is a new beginning.",
  "Sometimes the dark is the only map."
];

const cards = [
  {
    tag: "PHOTOGRAPHY",
    title: "Fotografování",
    text: "Moments, landscapes, details. My view of the world through the lens.",
    link: "/foto"
  },
  {
    tag: "TRAVEL",
    title: "Cestování",
    text: "Roads, cities, deserts and oceans. Travel diaries and stories.",
    link: "/cestovani"
  },
  {
    tag: "PROJECTS",
    title: "Moje projekty",
    text: "Code, ideas, experiments. Things I build along the way.",
    link: "/projekty"
  },
  {
    tag: "ZAJDA",
    title: "Zajda",
    text: "My story, my diagnosis, my universe.",
    link: "/zajda"
  }
];
---

<section class="page">

  <!-- HERO -->
  <header class="hero">
    <p class="hero-kicker">MY DIAGNOSIS: MY UNIVERSE</p>
    <h1 class="hero-title">MOJE DIAGNÓZA, MŮJ VESMÍR</h1>
    <p class="hero-subtitle">
      A quiet corner of the universe where I write, travel, photograph and try to make sense of it all.
    </p>

    <!-- FLOATING STAR TEXTS -->
    <div class="floating-quotes">
      {quotes.map((q, i) => (
        <span class={`floating-quote q-${i}`}>{q}</span>
      ))}
    </div>
  </header>

  <!-- CARDS -->
  <main class="content">
    <section class="cards">
      {cards.map((card, i) => (
        <a href={card.link} class={`card card-${i}`}>
          <div class="card-tag">{card.tag}</div>
          <h2 class="card-title">{card.title}</h2>
          <p class="card-text">{card.text}</p>
          <span class="card-link">Open →</span>
        </a>
      ))}
    </section>
  </main>

  <!-- FOOTER -->
  <footer class="footer">
    <p class="footer-text">“Hope is a quiet fire. Even in the dark, it remembers your name.”</p>
  </footer>

</section>

<style>
  :root {
    color-scheme: dark;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top, rgba(255, 140, 58, 0.18), transparent 55%),
      radial-gradient(circle at 10% 90%, rgba(120, 80, 255, 0.18), transparent 55%),
      radial-gradient(circle at 90% 10%, rgba(255, 255, 255, 0.06), transparent 60%),
      #050509;
    font-family: system-ui, sans-serif;
    color: #f3f3f3;
  }

  .page {
    max-width: 1120px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 2rem;
  }

  /* HERO */
  .hero-kicker {
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 0.8rem;
    color: #ffb87a;
    margin: 0 0 0.6rem;
    opacity: 0;
    transform: translateY(12px);
    animation: fadeUp 0.6s ease forwards 0.1s;
  }

  .hero-title {
    font-size: 3.8rem;
    font-weight: 900;
    letter-spacing: 0.02em;
    margin: 0;
    background: linear-gradient(120deg, #ffe8c8, #ff8c3a);
    -webkit-background-clip: text;
    color: transparent;
    text-shadow:
      0 0 22px rgba(255, 140, 58, 0.55),
      0 0 42px rgba(255, 140, 58, 0.35);
    opacity: 0;
    transform: translateY(22px);
    animation: fadeUp 0.8s ease forwards 0.2s;
  }

  .hero-subtitle {
    margin: 0.9rem 0 1.6rem;
    font-size: 1rem;
    color: #d0d0dd;
    max-width: 540px;
    opacity: 0;
    transform: translateY(18px);
    animation: fadeUp 0.7s ease forwards 0.3s;
  }

  /* FLOATING STAR TEXTS */
  .floating-quotes {
    position: relative;
    height: 260px;
    margin-top: 2rem;
  }

  .floating-quote {
    position: absolute;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.45);
    font-style: italic;
    pointer-events: auto;
    opacity: 0.65;
    transition: opacity 0.4s ease, text-shadow 0.4s ease;
    animation: drift 14s ease-in-out infinite alternate;
  }

  /* Random positions */
  .q-0 { top: 10%; left: 5%; }
  .q-1 { top: 35%; left: 70%; }
  .q-2 { top: 60%; left: 15%; }
  .q-3 { top: 20%; left: 55%; }
  .q-4 { top: 75%; left: 40%; }
  .q-5 { top: 50%; left: 85%; }

  /* Floating animation */
  @keyframes drift {
    0%   { transform: translate(0px, 0px); }
    50%  { transform: translate(12px, -18px); }
    100% { transform: translate(-10px, 10px); }
  }

  /* Hover glow */
  .floating-quote:hover {
    opacity: 1;
    text-shadow:
      0 0 12px rgba(255, 140, 58, 0.9),
      0 0 22px rgba(255, 140, 58, 0.6);
    animation: glowout 2s forwards;
  }

  /* Fade out after 2s */
  @keyframes glowout {
    0%   { opacity: 1; }
    100% { opacity: 0.55; text-shadow: none; }
  }

  /* CARDS */
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1.6rem;
    margin-top: 1.5rem;
  }

  .card {
    padding: 1.4rem;
    border-radius: 18px;
    background: radial-gradient(circle at top left, rgba(255, 140, 58, 0.16), transparent 55%), rgba(10, 10, 18, 0.96);
    border: 1px solid rgba(255, 255, 255, 0.06);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: 0.18s ease;
    opacity: 0;
    transform: translateY(22px);
  }

  .card-0 { animation: fadeUp 0.6s ease forwards 0.35s; }
  .card-1 { animation: fadeUp 0.6s ease forwards 0.42s; }
  .card-2 { animation: fadeUp 0.6s ease forwards 0.49s; }
  .card-3 { animation: fadeUp 0.6s ease forwards 0.56s; }

  .card:hover {
    transform: translateY(-6px);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.7);
    border-color: rgba(255, 140, 58, 0.7);
  }

  .card-tag {
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #ffb87a;
  }

  .card-title {
    margin: 0;
    font-size: 1.3rem;
  }

  .card-text {
    margin: 0;
    font-size: 0.95rem;
    color: #d4d4e0;
  }

  .card-link {
    margin-top: 1.1rem;
    font-size: 0.9rem;
    color: #ffdca8;
  }

  /* FOOTER */
  .footer {
    margin-top: 2.4rem;
    padding-top: 1.4rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer-text {
    margin: 0;
    font-size: 0.85rem;
    color: #a8a8ba;
    font-style: italic;
  }

  /* ANIMATIONS */
  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
