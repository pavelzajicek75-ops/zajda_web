---
const { title, noAuth = false } = Astro.props;
---
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
  </head>
  <body>
    {noAuth ? (
      <slot />
    ) : (
      <>
        <script type="module">
          const token = localStorage.getItem("admin_token");
          if (!token) window.location.href = "/admin/prihlaseni";
        </script>
        <nav>
          <a href="/admin">Dashboard</a>
          <a href="/admin/articles">Články</a>
          <a href="/admin/sections">Sekce</a>
          <a href="/admin/subsections">Podsekce</a>
          <a href="/admin/logout">Odhlásit</a>
        </nav>
        <slot />
      </>
    )}
  </body>
</html>
