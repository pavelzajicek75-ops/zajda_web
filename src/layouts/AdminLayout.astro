---
const { title, noAuth = false } = Astro.props;
---

<html>
  <head>
    <title>{title}</title>
  </head>

  <body>
    {noAuth ? (
      // 🔥 Login stránka – žádná kontrola tokenu
      <slot />
    ) : (
      <>
        <!-- 🔥 Admin stránky – kontrola tokenu -->
        <script type="module">
          const token = localStorage.getItem("admin_token");
          if (!token) {
            window.location.href = "/admin/login";
          }
        </script>

        <nav>
          <a href="/admin">Dashboard</a>
          <a href="/admin/articles">Články</a>
          <a href="/admin/upload">Upload</a>
        </nav>

        <slot />
      </>
    )}
  </body>
</html>
