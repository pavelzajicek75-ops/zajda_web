---
const { title, noAuth = false } = Astro.props;
---

<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <style>
      body {
        margin: 0;
        background: #121212;
        color: white;
        font-family: system-ui, sans-serif;
      }

      header {
        background: #1e1e1e;
        padding: 15px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #333;
      }

      nav a {
        color: #ccc;
        margin-right: 20px;
        text-decoration: none;
      }

      nav a:hover {
        color: white;
      }

      .logout {
        cursor: pointer;
        color: #ff6b6b;
      }

      main {
        padding: 20px;
      }
    </style>
  </head>

  <body>
    {noAuth ? (
      <main>
        <slot />
      </main>
    ) : (
      <>
        <script>
          document.addEventListener("DOMContentLoaded", () => {
            const token = localStorage.getItem("admin_token");
            if (!token) {
              window.location.href = "/admin/login";
            }
          });
        </script>

        <header>
          <nav>
            <a href="/admin">Dashboard</a>
            <a href="/admin/articles">Články</a>
            <a href="/admin/sections">Sekce</a>
            <a href="/admin/subsections">Podsekce</a>
          </nav>

          <div class="logout" onclick="logout()">Odhlásit</div>
        </header>

        <main>
          <slot />
        </main>

        <script>
          function logout() {
            localStorage.removeItem("admin_token");
            window.location.href = "/admin/login";
          }
        </script>
      </>
    )}
  </body>
</html>
