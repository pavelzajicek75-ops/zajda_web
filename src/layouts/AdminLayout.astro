---
const { title, noAuth = false } = Astro.props;
---

<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <style>
      body {
        background: #111;
        color: white;
        font-family: sans-serif;
        margin: 0;
        padding: 20px;
      }
      nav {
        display: flex;
        gap: 20px;
        background: #222;
        padding: 10px 20px;
        margin-bottom: 30px;
      }
      nav a {
        color: #4a90e2;
        text-decoration: none;
      }
      nav a:hover {
        text-decoration: underline;
      }
    </style>
  </head>

  <body>
    {noAuth ? (
      // 🔓 Login stránka – bez kontroly tokenu
      <slot />
    ) : (
      <>
        <!-- 🔒 Admin stránky – kontrola tokenu -->
        <script type="module">
          const token = localStorage.getItem("admin_token");
          if (!token) {
            window.location.href = "/admin/login";
          }
        </script>

        <nav>
          <a href="/admin">Dashboard</a>
          <a href="/admin/articles">Články</a>
          <a href="/admin/sections">Sekce</a>
          <a href="/admin/subsections">Podsekce</a>
          <a href="/admin/logout">Odhlásit</a>
        </nav>

        <slot />
      </>
    )}
  </body>
</html>
