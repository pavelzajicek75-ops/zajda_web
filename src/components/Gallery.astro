---
const { photos, title } = Astro.props;
---

<div class="gallery">
  {photos.map((src) => (
    <img src={src} alt={title} loading="lazy" />
  ))}
</div>

<style>
.gallery {
  margin-top: 2rem;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 1rem;
}

.gallery img {
  width: 100%;
  border-radius: var(--radius);
  object-fit: cover;
  transition: var(--transition);
}

.gallery img:hover {
  transform: scale(1.03);
}
</style>
