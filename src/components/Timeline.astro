---
const { items } = Astro.props;
---

<div class="timeline">
  {items.map((item) => (
    <div class="entry">
      <div class="dot"></div>
      <div class="content">
        <div class="date">{item.date}</div>
        <h3>{item.title}</h3>
        <a href={`/cestovani/usa2026/${item.file.replace(".json", "")}`}>Zobrazit den</a>
      </div>
    </div>
  ))}
</div>

<style>
.timeline {
  border-left: 2px solid var(--accent);
  padding-left: 2rem;
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.entry {
  position: relative;
}

.dot {
  position: absolute;
  left: -1.2rem;
  top: 0.4rem;
  width: 14px;
  height: 14px;
  background: var(--accent);
  border-radius: 50%;
}

.date {
  color: var(--text-muted);
  font-size: 0.9rem;
  margin-bottom: 0.3rem;
}

.content {
  background: var(--surface);
  padding: 1rem 1.5rem;
  border-radius: var(--radius);
  transition: var(--transition);
}

.content:hover {
  background: var(--surface-hover);
  transform: translateX(5px);
}
</style>
